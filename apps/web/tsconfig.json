{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2023",
      "ESNext.Disposable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": [
      "node",
      "react",
      "react-dom",
      "vite/client",
      "vitest/globals"
    ]
  },
  "include": [
    "src",
    "vite.config.js"
  ]
}
