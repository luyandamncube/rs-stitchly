    {
      "type_id": "text_input",
      "version": 1,
      "display_name": "Text Input",
      "category": "input",
      "description": "Injects literal text into the workflow.",
      "inputs": [],
      "outputs": [
        {
          "port_id": "text",
          "display_name": "Text",
          "direction": "output",
          "data_type": "text",
          "required": true,
          "multiple": false,
          "description": "The provided text payload."
        }
      ],
      "config_schema": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "title": "Text"
          },
          "trim_mode": {
            "type": "string",
            "enum": [
              "automatic",
              "trim",
              "exact"
            ],
            "default": "automatic"
          },
          "preserve_whitespace": {
            "type": "boolean",
            "default": true
          },
          "include_line_breaks": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "runtime": {
        "executor_kind": "rust_native",
        "isolation_mode": "in_process"
