          "variant": "input",
          "icon_key": "table_output",
          "top_chip": {
            "visible": false
          },
          "header": {
            "title_source": "instance_label_or_display_name",
            "show_overflow_menu": true
          },
          "rows": [
            {
              "row_id": "schema_name",
              "kind": "kv",
              "label": "Schema",
              "value": {
                "source": "config",
                "path": "schema_name"
              },
              "formatter": "text",
              "icon_key": "table_output",
              "truncate": false
            },
            {
              "row_id": "table_name",
              "kind": "kv",
              "label": "Table",
              "value": {
                "source": "config",
                "path": "table_name"
              },
              "formatter": "text",
              "icon_key": "label",
              "truncate": false
            }
          ],
          "footer": {
            "kind": "metric",
